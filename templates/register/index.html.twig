{% extends "layouts/base.html.twig" %}

{% block title 'Inscription | ' ~ parent() %}
{% block content %}
    <div class="jumbotron">
        <h3 class="display-6 text-center">Inscription</h3>
        <br>
        <div class="login-form">
            {{ form_start(form)}}
                <div class="row d-flex justify-content-center">
                    <div class="col-md-7">{{ form_row(form.firstName)}}</div>
                    <div class="col-md-7">{{ form_row(form.lastName)}}</div>
                    <div class="col-md-7">{{ form_row(form.email)}}</div>
                    <div class="col-md-7">{{ form_row(form.password)}}</div>
                <br>
                </div>
                    {{ form_widget(form)}}
                <div class="d-flex justify-content-center">
                    <button class="btn btn-info fas fa-check">{{button|default(" S'inscrire")}}</button>
                </div>
                    <hr>
                    <p class="text-center">
                        <a class="text-warning" href="{{path('app_login')}}">Vous avez déjà un compte</a>
                    </p>
            {{ form_end(form)}}
        </div>
    </div>

{% endblock %}
