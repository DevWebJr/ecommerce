{% extends "layouts/base.html.twig" %}

{% block title 'Mon Panier | ' ~ parent() %}

{% block content %}

    <div class="jumbotron">
        <h2 class="display-6">Mon Panier</h2>
        <p class="lead">Retrouvez l'ensemble des produits ajoutés à votre panier.</p>
        <table class="table mt-3">
            <thead>
                <tr>
                    <th scope="col" class="customized-name-title">Article</th>
                    <th scope="col"></th>
                    <th scope="col">Prix</th>
                    <th scope="col" class="customized-quantity-title">Quantité</th>
                    <th scope="col" class="customized-price-title">Total</th>
                </tr>
            </thead>

            <tbody>
            {% set total = null %}
            {% for product in cart %}
                <tr>
                    {# <th scope="row">{{}} </th> #}
                    <td class="illustration-min">
                        <img src=" {{ asset('/uploads/' ~ product.product.picture)}} " alt="{{ product.product.name }}" title="{{ product.product.name }}" class="img-fluid ">
                    </td>
                    <td class="customized-name">{{ product.product.name }}</td>
                    <td>{{ product.product.formattedPrice }} €</td>
                    <td class="customized-quantity">X {{ product.quantity}}</td>
                    <td class="customized-price">{{ (product.product.price/100)|number_format(2, ',', '.') }} €</td>
                    <td class="customized-price">{{ ((product.product.price * product.quantity) /100)|number_format(2, ',', '.') }} €</td>
                </tr>
            {% set total = total + (product.product.price * product.quantity) %}
            {% endfor %}
            </tbody>
        </table>

        <div class="vertical-space-1"></div>

        <hr/>

        <div class="vertical-space-3"></div>

        <div class="text-center mb-3 d-flex justify-content-around">
            <b><span class="customized-quantity-title"> {{ cart|length }} </span> article(s) pour un total de <span class="customized-price-title"> {{ total/100|number_format(2, ',', '.') }} €</span></b>
        </div>
            <div class="vertical-space-3"></div>

        <div class="lead d-flex justify-content-center">
            <a class="btn btn-success btn-lg" href="#" role="button">Valider</a>
            <div class="horizontal-space-2"></div>
            <a class="btn btn-danger btn-lg" href="{{path('remove_cart')}} " role="button">
                <i class="fas fa-trash"></i>
            </a>
        </div>

        <p class="lead">
        </p>
    </div>

{% endblock %}