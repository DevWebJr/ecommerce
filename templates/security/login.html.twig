{% extends 'layouts/base.html.twig' %}

{% block title 'Connexion | ' ~ parent() %}

{% block content %}
<div class="jumbotron">
    <h3 class="display-6 text-center">
            <i class="fas fa-user user-color"></i> 
             Connexion
        </h3>
    <div class="login-form row d-flex justify-content-center">
        <form method="post" class="col-md-7">
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            <label for="inputEmail"></label>
            <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control placeholder-custmomized" placeholder="Email" required autofocus>
            <label for="inputPassword"></label>
            <input type="password" name="password" id="inputPassword" class="form-control placeholder-custmomized" placeholder="Mot De Passe" required>

            <input type="hidden" name="_csrf_token"
                value="{{ csrf_token('authenticate') }}"
            >

            {#
                Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                See https://symfony.com/doc/current/security/remember_me.html

                <div class="checkbox mb-3">
                    <label>
                        <input type="checkbox" name="_remember_me"> Remember me
                    </label>
                </div>
            #}
            <br>
            <div class="d-flex justify-content-center">
                <button class="btn btn-info fas fa-check" type="submit">
                    Se connecter
                </button>
            </div>
                <hr>
                <p class="text-center">
                    <a class="text-warning" href="{{path('register')}}">Créer un compte</a>
                </p>
        </form>
    </div>
</div>
{% endblock %}
